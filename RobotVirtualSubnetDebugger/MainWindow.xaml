<Window x:Class="RobotNet.Windows.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RobotNet.Windows.Wpf"
        Height="760"
        MinHeight="620"
        MinWidth="1040"
        Width="1240"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="22,26,22,18">
                    <TextBlock Text="RobotNet"
                               Foreground="White"
                               FontSize="25"
                               FontWeight="SemiBold" />
                    <TextBlock Text="虚拟网段远程调试"
                               Margin="0,6,0,0"
                               Foreground="#B5C1CD"
                               FontSize="13" />
                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Margin="18,16,18,22"
                        Padding="12"
                        Background="#223142"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="MVP 安全模式"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="13" />
                        <TextBlock Text="不修改系统网络配置"
                                   Margin="0,4,0,0"
                                   Foreground="#B5C1CD"
                                   FontSize="12" />
                    </StackPanel>
                </Border>

                <ListBox ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="White"
                         DisplayMemberPath="Title"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                            <Setter Property="Margin" Value="14,2" />
                            <Setter Property="Padding" Value="13,10" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Background="Transparent"
                                                CornerRadius="7"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.42" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Padding="30">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>
    </Grid>
</Window>
