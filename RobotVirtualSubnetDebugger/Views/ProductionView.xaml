<UserControl x:Class="RobotNet.Windows.Wpf.Views.ProductionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="发布与更新 Release"
                           Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="第六阶段：GitHub Releases 更新、发布包下载、崩溃报告、持久化日志和发布检查。"
                           Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        Margin="16,6,0,0">
                <Button Width="110"
                        Height="36"
                        Margin="0,0,10,0"
                        Command="{Binding CheckUpdatesCommand}"
                        Content="检查更新" />
                <Button Width="110"
                        Height="36"
                        Margin="0,0,10,0"
                        Command="{Binding DownloadUpdateCommand}"
                        Content="下载更新" />
                <Button Width="130"
                        Height="36"
                        Command="{Binding OpenReleasePageCommand}"
                        Content="打开 Releases" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,24,0,0"
                Background="White"
                BorderBrush="#DDE3EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="当前版本" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentVersion}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="0" Grid.Column="2" Text="GitHub 仓库" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding RepositoryText}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="1" Text="更新状态" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Grid.ColumnSpan="3"
                           Text="{Binding UpdateStatus}"
                           TextWrapping="Wrap"
                           Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="2" Text="下载状态" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Grid.ColumnSpan="3"
                           Text="{Binding DownloadStatus}"
                           TextWrapping="Wrap"
                           Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="3" Text="下载路径" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Grid.ColumnSpan="3"
                           Text="{Binding DownloadPath}"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           Style="{StaticResource DashboardValueStyle}" />

                <StackPanel Grid.Row="4"
                            Grid.ColumnSpan="4"
                            Orientation="Horizontal"
                            Margin="0,8,0,0">
                    <Button Width="110"
                            Height="34"
                            Margin="0,0,10,0"
                            Command="{Binding OpenLogsFolderCommand}"
                            Content="日志目录" />
                    <Button Width="110"
                            Height="34"
                            Margin="0,0,10,0"
                            Command="{Binding OpenCrashFolderCommand}"
                            Content="崩溃目录" />
                    <Button Width="110"
                            Height="34"
                            Command="{Binding OpenUpdatesFolderCommand}"
                            Content="更新目录" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="1"
                    Margin="0,0,18,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="发布检查项"
                               Margin="18,16,18,8"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <ListView ItemsSource="{Binding Checklist}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="项目" Width="130" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="状态" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="{Binding StatusColor}"
                                                       FontWeight="SemiBold" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="说明" Width="210" DisplayMemberBinding="{Binding Detail}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="GitHub Release 资源"
                               Margin="18,16,18,8"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <ListView ItemsSource="{Binding Assets}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="文件" Width="360" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="大小" Width="90" DisplayMemberBinding="{Binding SizeText}" />
                                <GridViewColumn Header="类型" Width="180" DisplayMemberBinding="{Binding ContentType}" />
                                <GridViewColumn Header="下载地址" Width="520" DisplayMemberBinding="{Binding DownloadUrl}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
