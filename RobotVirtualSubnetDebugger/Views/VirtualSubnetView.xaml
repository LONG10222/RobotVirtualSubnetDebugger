<UserControl x:Class="RobotNet.Windows.Wpf.Views.VirtualSubnetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="虚拟网段 Virtual Subnet"
                           Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="第五阶段：生成目标网段精确路由与网关端 NAT 的管理员脚本，保留 WiFi、VPN、默认路由和 DNS。"
                           Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        Margin="16,6,0,0">
                <Button Width="100"
                        Height="36"
                        Margin="0,0,10,0"
                        Command="{Binding RefreshCommand}"
                        Content="刷新计划" />
                <Button Width="120"
                        Height="36"
                        Command="{Binding ExportScriptsCommand}"
                        Content="生成脚本" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,24,0,0"
                Background="White"
                BorderBrush="#DDE3EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="状态" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding StatusText}"
                           Foreground="{Binding StatusColor}"
                           Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="0" Grid.Column="2" Text="角色" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding RoleText}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="1" Text="路线" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ModeText}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="1" Grid.Column="2" Text="目标网段" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding TargetSubnetCidr}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="2" Text="LAN 网段" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LanSubnetCidr}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="2" Grid.Column="2" Text="网关端 LAN IP" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding GatewayLanIp}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="3" Text="LAN 网卡" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LanInterfaceName}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="3" Grid.Column="2" Text="目标网卡" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding TargetInterfaceName}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="4" Text="上网/VPN 共存" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Grid.ColumnSpan="4"
                           Text="{Binding RouteSafetyText}"
                           TextWrapping="Wrap"
                           Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="5" Text="摘要" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="5"
                           Grid.Column="1"
                           Grid.ColumnSpan="4"
                           Text="{Binding Summary}"
                           TextWrapping="Wrap"
                           Style="{StaticResource DashboardValueStyle}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    Margin="0,0,18,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="风险与约束"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12" />
                    <ListBox ItemsSource="{Binding Warnings}"
                             BorderThickness="0"
                             Foreground="{StaticResource TextSecondaryBrush}" />
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListView ItemsSource="{Binding Steps}"
                              BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="#" Width="42" DisplayMemberBinding="{Binding Order}" />
                                <GridViewColumn Header="步骤" Width="150" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="风险" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RiskLevel}"
                                                       Foreground="{Binding RiskColor}"
                                                       FontWeight="SemiBold" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="说明" Width="300" DisplayMemberBinding="{Binding Description}" />
                                <GridViewColumn Header="命令预览" Width="520" DisplayMemberBinding="{Binding Command}" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Grid.Row="1" Margin="18,12,18,18">
                        <TextBlock Text="{Binding ScriptMessage}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding ApplyScriptPath}"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding RollbackScriptPath}"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
