<UserControl x:Class="RobotNet.Windows.Wpf.Views.SessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="连接会话 Session"
                           Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="第二阶段：模拟隧道握手和会话状态，不创建真实虚拟网卡，不修改路由，不转发真实流量。"
                           Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        Margin="16,6,0,0">
                <Button Width="120"
                        Height="36"
                        Margin="0,0,10,0"
                        Command="{Binding StartCommand}"
                        Content="启动模拟会话" />
                <Button Width="100"
                        Height="36"
                        Command="{Binding StopCommand}"
                        Content="停止会话" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,24,0,0"
                Background="White"
                BorderBrush="#DDE3EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="状态" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding StatusText}"
                           Foreground="{Binding StatusColor}"
                           Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="0" Grid.Column="2" Text="会话 ID" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding SessionId}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="1" Text="本机角色" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RoleText}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="1" Grid.Column="2" Text="网关端 LAN IP" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding GatewayLanIp}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="2" Text="目标设备 IP" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TargetDeviceIp}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="2" Grid.Column="2" Text="虚拟 IP" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding VirtualIp}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="3" Text="已连接对端" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PeerDeviceName}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="2"
                           Text="对端 LAN IP"
                           Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="3"
                           Grid.Column="3"
                           Text="{Binding PeerLanIp}"
                           Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="4" Text="最后更新" Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastUpdatedText}" Style="{StaticResource DashboardValueStyle}" />

                <TextBlock Grid.Row="4"
                           Grid.Column="2"
                           Text="说明"
                           Style="{StaticResource DashboardLabelStyle}" />
                <TextBlock Grid.Row="4"
                           Grid.Column="3"
                           Grid.ColumnSpan="2"
                           Text="{Binding Message}"
                           TextWrapping="Wrap"
                           Style="{StaticResource DashboardValueStyle}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,18,0,0"
                Background="White"
                BorderBrush="#DDE3EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="1">
            <ListView ItemsSource="{Binding Steps}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="时间" Width="90" DisplayMemberBinding="{Binding TimestampText}" />
                        <GridViewColumn Header="步骤" Width="160" DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="状态" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{Binding StatusColor}"
                                               FontWeight="SemiBold" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="说明" Width="560" DisplayMemberBinding="{Binding Message}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</UserControl>
