<UserControl x:Class="RobotNet.Windows.Wpf.Views.AdaptersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="网卡管理 Adapters"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#18212C" />
                <TextBlock Text="{Binding LastRefreshMessage}"
                           Margin="0,8,0,0"
                           Foreground="#5B6673"
                           FontSize="14" />
            </StackPanel>

            <Button DockPanel.Dock="Right"
                    Width="120"
                    Height="36"
                    Margin="16,6,0,0"
                    Command="{Binding RefreshCommand}"
                    Content="刷新网卡" />
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,24,0,0"
                Background="White"
                BorderBrush="#DDE3EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="1">
            <ListView ItemsSource="{Binding Adapters}"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="名称" Width="180" DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="IPv4" Width="120" DisplayMemberBinding="{Binding IPv4Address}" />
                        <GridViewColumn Header="掩码" Width="120" DisplayMemberBinding="{Binding SubnetMask}" />
                        <GridViewColumn Header="网关" Width="120" DisplayMemberBinding="{Binding Gateway}" />
                        <GridViewColumn Header="MAC" Width="140" DisplayMemberBinding="{Binding MacAddress}" />
                        <GridViewColumn Header="状态" Width="90" DisplayMemberBinding="{Binding Status}" />
                        <GridViewColumn Header="类型" Width="110" DisplayMemberBinding="{Binding Type}" />
                        <GridViewColumn Header="虚拟" Width="70" DisplayMemberBinding="{Binding IsVirtual}" />
                        <GridViewColumn Header="目标网段候选" Width="110" DisplayMemberBinding="{Binding IsTargetNetworkCandidate}" />
                        <GridViewColumn Header="局域网候选" Width="100" DisplayMemberBinding="{Binding IsLanCandidate}" />
                        <GridViewColumn Header="DNS" Width="220" DisplayMemberBinding="{Binding DnsServersText}" />
                        <GridViewColumn Header="描述" Width="260" DisplayMemberBinding="{Binding Description}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</UserControl>
