<UserControl x:Class="RobotNet.Windows.Wpf.Views.EasyModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="简易模式 / 一键连接"
                       Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="适合普通用户：主机 A 插网线连接硬件设备，主机 B 运行控制代码，两台电脑连同一个 WiFi。"
                       Style="{StaticResource PageSubtitleStyle}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,22,0,0"
                Background="White"
                BorderBrush="#DDE3EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Height="44"
                        Margin="0,0,10,0"
                        Command="{Binding SelectGatewayRoleCommand}"
                        Content="这台电脑连接硬件设备（主机 A / 网关端）" />
                <Button Grid.Column="1"
                        Height="44"
                        Margin="10,0,0,0"
                        Command="{Binding SelectClientRoleCommand}"
                        Content="这台电脑运行控制代码（主机 B / 调试端）" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,18,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="当前步骤"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding RoleText}"
                                   Margin="0,8,0,16"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="硬件设备 IP" Style="{StaticResource DashboardLabelStyle}" />
                        <TextBox Height="32"
                                 Margin="0,0,0,12"
                                 Text="{Binding TargetDeviceIp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="硬件设备端口" Style="{StaticResource DashboardLabelStyle}" />
                        <TextBox Height="32"
                                 Margin="0,0,0,12"
                                 Text="{Binding TargetDevicePort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="主机 A 设备网口 IP" Style="{StaticResource DashboardLabelStyle}" />
                        <TextBox Height="32"
                                 Margin="0,0,0,12"
                                 Text="{Binding TargetDeviceAdapterIp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="子网掩码" Style="{StaticResource DashboardLabelStyle}" />
                        <TextBox Height="32"
                                 Margin="0,0,0,12"
                                 Text="{Binding VirtualSubnetMask, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="本地监听端口" Style="{StaticResource DashboardLabelStyle}" />
                        <TextBox Height="32"
                                 Margin="0,0,0,12"
                                 Text="{Binding LocalListenPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="主机 A 局域网 IP" Style="{StaticResource DashboardLabelStyle}" />
                        <TextBox Height="32"
                                 Margin="0,0,0,12"
                                 Text="{Binding GatewayLanIp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="发现到的主机 A" Style="{StaticResource DashboardLabelStyle}" />
                        <ComboBox Height="32"
                                  Margin="0,0,0,14"
                                  ItemsSource="{Binding Gateways}"
                                  SelectedItem="{Binding SelectedGateway, Mode=TwoWay}"
                                  DisplayMemberPath="ComputerName" />

                        <Button Height="36"
                                Margin="0,4,0,10"
                                Command="{Binding RefreshGatewaysCommand}"
                                Content="刷新主机 A" />
                        <Button Height="36"
                                Margin="0,0,0,10"
                                Command="{Binding PreviewCommand}"
                                Content="预览将要执行的操作" />
                        <Button Height="38"
                                Margin="0,0,0,10"
                                Command="{Binding ApplyGatewayCommand}"
                                Content="配置网口并启动网关" />
                        <Button Height="38"
                                Margin="0,0,0,10"
                                Command="{Binding ApplyClientCommand}"
                                Content="连接主机 A 并启动调试通道" />
                        <Button Height="36"
                                Command="{Binding RollbackCommand}"
                                Content="恢复网络配置" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="160" />
                </Grid.RowDefinitions>

                <Border Background="White"
                        BorderBrush="#DDE3EA"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="{Binding ApplyStatusText}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding Status}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PlanSummary}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        Background="White"
                        BorderBrush="#DDE3EA"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="1">
                    <ListView ItemsSource="{Binding PreviewSteps}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="#" Width="42" DisplayMemberBinding="{Binding Order}" />
                                <GridViewColumn Header="操作" Width="160" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="风险" Width="70" DisplayMemberBinding="{Binding RiskLevel}" />
                                <GridViewColumn Header="说明" Width="320" DisplayMemberBinding="{Binding Description}" />
                                <GridViewColumn Header="命令预览" Width="520" DisplayMemberBinding="{Binding Command}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,18,0,0"
                        Background="White"
                        BorderBrush="#DDE3EA"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <ListBox ItemsSource="{Binding ExecutionLogs}"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="12" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
