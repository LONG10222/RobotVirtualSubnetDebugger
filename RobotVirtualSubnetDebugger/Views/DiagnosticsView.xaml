<UserControl x:Class="RobotNet.Windows.Wpf.Views.DiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="诊断 Diagnostics"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#18212C" />
                <TextBlock Text="{Binding Status}"
                           Margin="0,8,0,0"
                           Foreground="#5B6673"
                           FontSize="14" />
            </StackPanel>

            <Button DockPanel.Dock="Right"
                    Width="120"
                    Height="36"
                    Margin="16,6,0,0"
                    Command="{Binding RunCommand}"
                    Content="运行诊断" />
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,24,0,0"
                Background="White"
                BorderBrush="#DDE3EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="1">
            <ListView ItemsSource="{Binding Results}"
                      BorderThickness="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="项目" Width="170" DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="状态" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{Binding StatusColor}"
                                               FontWeight="SemiBold" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="结果" Width="360" DisplayMemberBinding="{Binding Message}" />
                        <GridViewColumn Header="建议" Width="420" DisplayMemberBinding="{Binding Suggestion}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</UserControl>
