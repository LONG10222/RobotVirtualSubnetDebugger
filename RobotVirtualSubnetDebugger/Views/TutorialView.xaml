<UserControl x:Class="RobotNet.Windows.Wpf.Views.TutorialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="操作教程 Tutorial"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#18212C" />
            <TextBlock Text="目标设备可以是机械臂、PLC、工控机、相机控制器或其他仅在独立网段内可访问的设备。机械臂只是示例。"
                       Margin="0,8,0,0"
                       Foreground="#5B6673"
                       FontSize="14"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      Margin="0,24,0,0"
                      VerticalScrollBarVisibility="Auto">
            <Border Background="White"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="一、先理解两台电脑的角色"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap"
                               Text="电脑 A 是网关端 GatewayAgent：它同时连接局域网和目标设备所在网段。电脑 B 是调试端 DebugClient：它运行你的调试代码，可以先通过安全 TCP 代理访问目标设备端口，也可以在第五阶段生成目标网段路由/NAT 脚本后访问目标设备网段。" />

                    <TextBlock Text="二、在电脑 A 上配置网关端"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="1. 打开“设置 Settings”，角色选择“网关端 GatewayAgent”。" />
                        <LineBreak />
                        <Run Text="2. 填写目标设备 IP，例如 192.168.1.10。" />
                        <LineBreak />
                        <Run Text="3. 填写目标设备端口，例如 30003。" />
                        <LineBreak />
                        <Run Text="4. 填写目标设备网卡 IP，例如电脑 A 上连接目标设备的网卡地址 192.168.1.100。" />
                        <LineBreak />
                        <Run Text="5. 保存配置。" />
                        <LineBreak />
                        <Run Text="6. 打开“网卡管理 Adapters”，确认有一个网卡被识别为目标网段候选。" />
                        <LineBreak />
                        <Run Text="7. 打开“诊断 Diagnostics”，运行诊断，检查目标设备 Ping 和 TCP 端口结果。" />
                    </TextBlock>

                    <TextBlock Text="三、在电脑 B 上配置调试端"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="1. 打开“设置 Settings”，角色选择“调试端 DebugClient”。" />
                        <LineBreak />
                        <Run Text="2. 填写目标设备 IP，例如 192.168.1.10。" />
                        <LineBreak />
                        <Run Text="3. 填写目标设备端口，例如 30003。" />
                        <LineBreak />
                        <Run Text="4. 填写虚拟 IP，例如 192.168.1.101。" />
                        <LineBreak />
                        <Run Text="5. 填写虚拟掩码，例如 255.255.255.0。" />
                        <LineBreak />
                        <Run Text="6. 填写网关端 LAN IP，例如电脑 A 的 WiFi/LAN 地址 192.168.31.20。" />
                        <LineBreak />
                        <Run Text="7. 保存配置。" />
                        <LineBreak />
                        <Run Text="8. 打开“诊断 Diagnostics”，运行诊断，检查电脑 B 到电脑 A 的局域网连通性和虚拟 IP 规划。" />
                    </TextBlock>

                    <TextBlock Text="四、使用设备发现"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="1. 两台电脑都运行本程序。" />
                        <LineBreak />
                        <Run Text="2. 两台电脑的“UDP 发现端口”必须一致，默认是 47831。" />
                        <LineBreak />
                        <Run Text="3. 分别打开“设备发现 Discovery”，点击“启动发现”。" />
                        <LineBreak />
                        <Run Text="4. 如果 Windows 防火墙弹窗，请允许专用网络访问。" />
                        <LineBreak />
                        <Run Text="5. 若网络正常，两台电脑会互相出现在发现列表中。" />
                    </TextBlock>

                    <TextBlock Text="五、使用安全 TCP 代理"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="1. 两台电脑都配置相同的 SharedKey。" />
                        <LineBreak />
                        <Run Text="2. 网关端打开“TCP 代理 Proxy”，启动网关端监听。" />
                        <LineBreak />
                        <Run Text="3. 调试端打开“TCP 代理 Proxy”，启动调试端本地监听。" />
                        <LineBreak />
                        <Run Text="4. 调试代码连接 127.0.0.1:LocalListenPort，例如默认 127.0.0.1:30003。" />
                        <LineBreak />
                        <Run Text="5. 程序会使用 SharedKey、HMAC-SHA256、AES-GCM、心跳和超时策略把 TCP 流量转发到网关端后的目标设备端口。" />
                    </TextBlock>

                    <TextBlock Text="六、生成虚拟网段脚本"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="1. 确认诊断页没有严重错误，尤其是目标设备 IP、网关端 LAN IP、目标设备网卡和端口。" />
                        <LineBreak />
                        <Run Text="2. 打开“虚拟网段 Virtual Subnet”，点击“刷新计划”。" />
                        <LineBreak />
                        <Run Text="3. 调试端计划会生成目标网段精确路由；网关端计划会生成网卡转发和 NAT。" />
                        <LineBreak />
                        <Run Text="4. 点击“生成脚本”，脚本保存到 %AppData%\RobotNet.Windows.Wpf\stage5。" />
                        <LineBreak />
                        <Run Text="5. 用管理员 PowerShell 审阅脚本，把确认变量改为 true 后再执行。" />
                        <LineBreak />
                        <Run Text="6. 需要撤销时执行同目录下的 rollback 脚本。" />
                    </TextBlock>

                    <TextBlock Text="七、安全边界"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="程序不会静默创建虚拟网卡、不会静默修改路由、不会静默启用 NAT、不会桥接网卡，也不会自动修改防火墙。第五阶段只生成可审阅的管理员脚本，真实系统修改必须由你手动确认执行。" />
                    </TextBlock>

                    <TextBlock Text="八、推荐检查顺序"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="1. 先确认网卡管理页面能看到正确的 LAN 网卡和目标网段网卡。" />
                        <LineBreak />
                        <Run Text="2. 再确认两台电脑可以通过设备发现互相看到。" />
                        <LineBreak />
                        <Run Text="3. 然后分别设置电脑 A 和电脑 B 的角色。" />
                        <LineBreak />
                        <Run Text="4. 最后运行诊断页面，逐项处理警告和错误。" />
                        <LineBreak />
                        <Run Text="5. 先用 TCP 代理验证真实端口转发，再决定是否生成并手动执行虚拟网段脚本。" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
