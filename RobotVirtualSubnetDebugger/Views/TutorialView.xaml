<UserControl x:Class="RobotNet.Windows.Wpf.Views.TutorialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="操作教程 Tutorial"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#18212C" />
            <TextBlock Text="目标设备可以是机械臂、PLC、工控机、相机控制器或其他仅在独立网段内可访问的设备。机械臂只是示例。"
                       Margin="0,8,0,0"
                       Foreground="#5B6673"
                       FontSize="14"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      Margin="0,24,0,0"
                      VerticalScrollBarVisibility="Auto">
            <Border Background="White"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="一、先理解两台电脑的角色"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap"
                               Text="电脑 A 是网关端 GatewayAgent：它插网线连接硬件设备，同时通过 WiFi 连接普通局域网。电脑 B 是调试端 DebugClient：它运行你的控制代码，通过 WiFi 找到电脑 A，再让流量转发到电脑 A 网口后的硬件设备。" />

                    <TextBlock Text="二、主机 A：我连接硬件设备"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="1. 把硬件设备用网线插到主机 A 的网口。" />
                        <LineBreak />
                        <Run Text="2. 确认主机 A 也连接到和主机 B 相同的 WiFi。" />
                        <LineBreak />
                        <Run Text="3. 打开“简易模式 / 一键连接”。" />
                        <LineBreak />
                        <Run Text="4. 点击“这台电脑连接硬件设备（主机 A / 网关端）”。" />
                        <LineBreak />
                        <Run Text="5. 填写或确认硬件设备 IP，例如 192.168.1.10。" />
                        <LineBreak />
                        <Run Text="6. 填写或确认硬件设备端口，例如 30003。" />
                        <LineBreak />
                        <Run Text="7. 填写或确认主机 A 设备网口 IP，例如 192.168.1.100。" />
                        <LineBreak />
                        <Run Text="8. 点击“生成配对密钥”，并把同一个密钥填到主机 B。" />
                        <LineBreak />
                        <Run Text="9. 点击“配置网口并等待连接”。完成后主机 A 只广播自身可用状态并监听，不主动搜索或连接其他电脑。" />
                    </TextBlock>

                    <TextBlock Text="三、主机 B：我运行控制代码"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="1. 确认主机 B 和主机 A 连接同一个 WiFi。" />
                        <LineBreak />
                        <Run Text="2. 打开“简易模式 / 一键连接”。" />
                        <LineBreak />
                        <Run Text="3. 点击“这台电脑运行控制代码（主机 B / 调试端）”。" />
                        <LineBreak />
                        <Run Text="4. 填写与主机 A 相同的配对密钥。" />
                        <LineBreak />
                        <Run Text="5. 点击“刷新主机 A”，选择发现到的主机 A。" />
                        <LineBreak />
                        <Run Text="6. 填写或确认硬件设备 IP 和端口，例如 192.168.1.10:30003。" />
                        <LineBreak />
                        <Run Text="7. 点击“连接主机 A 并启动调试通道”。" />
                        <LineBreak />
                        <Run Text="8. 完成后，你的控制代码继续访问硬件设备 IP/端口，流量会通过主机 A 转发。" />
                    </TextBlock>

                    <TextBlock Text="四、使用设备发现"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="1. 两台电脑都运行本程序。" />
                        <LineBreak />
                        <Run Text="2. 两台电脑的“UDP 发现端口”必须一致，默认是 47831。" />
                        <LineBreak />
                        <Run Text="3. 分别打开“设备发现 Discovery”，点击“启动发现”。" />
                        <LineBreak />
                        <Run Text="4. 如果 Windows 防火墙弹窗，请允许专用网络访问。" />
                        <LineBreak />
                        <Run Text="5. 若网络正常，两台电脑会互相出现在发现列表中。" />
                    </TextBlock>

                    <TextBlock Text="五、使用安全 TCP 代理"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="1. 两台电脑都配置相同的 SharedKey。" />
                        <LineBreak />
                        <Run Text="2. 网关端打开“TCP 代理 Proxy”，启动网关端监听。" />
                        <LineBreak />
                        <Run Text="3. 调试端打开“TCP 代理 Proxy”，启动调试端本地监听。" />
                        <LineBreak />
                        <Run Text="4. 调试代码连接 127.0.0.1:LocalListenPort，例如默认 127.0.0.1:30003。" />
                        <LineBreak />
                        <Run Text="5. 程序会使用 SharedKey、HMAC-SHA256、AES-GCM、心跳和超时策略把 TCP 流量转发到网关端后的目标设备端口。" />
                    </TextBlock>

                    <TextBlock Text="六、虚拟网段与高级选项"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="1. 普通用户优先使用“简易模式 / 一键连接”。" />
                        <LineBreak />
                        <Run Text="2. “虚拟网段 Virtual Subnet”页面可以查看将要执行的路由、转发和 NAT 操作。" />
                        <LineBreak />
                        <Run Text="3. 点击“一键应用”会在程序内部执行网络配置。" />
                        <LineBreak />
                        <Run Text="4. 点击“回滚配置”可以恢复上次由本程序应用的网络配置。" />
                        <LineBreak />
                        <Run Text="5. “导出脚本”只作为高级调试和审计用途，不是普通用户主流程。" />
                    </TextBlock>

                    <TextBlock Text="七、安全边界"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,18"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="程序启动时会请求管理员权限。所有网络修改都会先显示操作预览，并写入审计日志；程序不会修改默认路由 0.0.0.0/0，不修改 DNS，不主动关闭 VPN，也不破坏正常 WiFi 上网。" />
                    </TextBlock>

                    <TextBlock Text="八、推荐检查顺序"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18212C" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#344054"
                               TextWrapping="Wrap">
                        <Run Text="1. 先确认网卡管理页面能看到正确的 LAN 网卡和目标网段网卡。" />
                        <LineBreak />
                        <Run Text="2. 再确认两台电脑可以通过设备发现互相看到。" />
                        <LineBreak />
                        <Run Text="3. 然后分别设置电脑 A 和电脑 B 的角色。" />
                        <LineBreak />
                        <Run Text="4. 最后运行诊断页面，逐项处理警告和错误。" />
                        <LineBreak />
                        <Run Text="5. 需要深入排查时，再进入“虚拟网段”“诊断”“日志”等高级页面。" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
